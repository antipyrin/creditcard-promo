# minimax API 密钥（从 C:\Users\antip\.mmx\config.json 复制 api_key 字段）
# 在 GitHub 仓库 Settings → Secrets → Actions 里配置为 MMX_API_KEY
MMX_API_KEY=sk-cb********************************

# 飞书自定义机器人 Webhook URL（主推送通道）
# 获取方式：飞书 App → 创建只有自己的群 → 设置 → 群机器人 → 添加自定义机器人 → 复制 webhook URL
# URL 格式：https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 在 GitHub Secrets 里配置为 FEISHU_WEBHOOK_URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/********************************

# PushPlus 推送 token（备用通道，飞书失败时启用）
# 在 GitHub Secrets 里配置为 PUSHPLUS_TOKEN
PUSHPLUS_TOKEN=********************************

# Server酱 SendKey（可选的备用通道）
# 在 GitHub Secrets 里配置为 SCT_SENDKEY
SCT_SENDKEY=SCT********************************

# GitHub Personal Access Token（网页控制台触发 workflow 用，可选）
# 在 GitHub Secrets 里配置为 GH_PAT
# GH_PAT=ghp_********************************